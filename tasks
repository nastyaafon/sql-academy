```mysql
SELECT user_id, item FROM Transactions
WHERE transaction_ts IN (
    SELECT MIN(transaction_ts) 
    FROM Transactions
    GROUP BY user_id);
```


```mysql
SELECT DISTINCT user_id, 
    FIRST_VALUE(item) OVER (
    PARTITION BY user_id 
    ORDER BY transaction_ts) item
FROM Transactions;
```


```mysql
SELECT DISTINCT user_id, (
    SELECT item FROM Transactions
    WHERE user_id=T.user_id
    ORDER BY transaction_ts
    LIMIT 1) item
FROM Transactions T;
```

</details>

